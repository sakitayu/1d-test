# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# vscode (commit only shared formatter settings)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# playwright
/test-results/
/playwright-report/
/playwright/.cache/

# AI agent instruction files (evaluator-facing repo; AI usage report goes in README)
AGENTS.md
CLAUDE.md

# AI session handoff artifacts (design doc lives locally; durable content goes in README)
/docs/
